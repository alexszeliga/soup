# Soup Environment Variables
NODE_ENV=development

# qBittorrent
QB_URL=http://localhost:8080
QB_USERNAME=
QB_PASSWORD=

# TMDB
TMDB_API_KEY=

# Database
DB_PATH=./soup.db

# Media Library
MEDIA_ROOT=./media

# Path Mapping (for remote qBittorrent or containers)
# Map qBittorrent's internal paths to where they are locally accessible to Soup
QB_DOWNLOAD_ROOT=/downloads
LOCAL_DOWNLOAD_ROOT=./downloads
