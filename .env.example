# Soup Environment Variables
NODE_ENV=production
SOUP_PORT=8207

# qBittorrent Configuration
QB_URL=http://localhost:8080/api/v2
QB_USERNAME=
QB_PASSWORD=

# TMDB Configuration
TMDB_API_KEY=

# Persistence
DB_PATH=./soup.db

# Media Library & Downloads
# When running locally: these are actual paths on your disk.
# When running in Docker: these are the HOST paths that will be mounted into the container.
MEDIA_ROOT=./media
LOCAL_DOWNLOAD_ROOT=./downloads

# qBittorrent Internal Download Root
# This is the path qBittorrent uses INTERNALLY (e.g. /downloads)
QB_DOWNLOAD_ROOT=/downloads

# Logging Level (debug, info, warn, error)
LOG_LEVEL=warn
